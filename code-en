# 1. Transformation (Michaelis-Menten) - Enzyme catalysis
def michaelis_menten(S, Vmax=500, Km=0.1):
    """Lactate dehydrogenase (LDH) catalyzing pyruvate reduction"""
    return Vmax * S / (Km + S)

# 2. Selection (Hill) - Hemoglobin cooperative binding
def hill_equation(L, n=2.8, p50=11.7, Ymax=1.0):
    """Hemoglobin oxygen binding: n≈2.8, p50≈11.7 torr"""
    return Ymax * (L**n) / (p50**n + L**n)

# 3. Stability (Boltzmann) - Protein folding
def boltzmann_folding(dG, RT=0.593):
    """ΔG in kcal/mol, RT≈0.593 kcal/mol at 298K"""
    return 1.0 / (1.0 + np.exp(-dG/RT))

# 4. Extension (Logistic) - Population growth
def logistic_growth(N, r=0.03, K=10e9):
    """Human population growth: r≈0.03/year, K≈10 billion"""
    return r * N * (1 - N/K)

# 5. Exchange (Langmuir) - Surface adsorption
def langmuir_adsorption(C, K_ads=1e6, theta_max=1.0):
    """K_ads=1e6 M⁻¹, corresponding to ΔG≈-34.2 kJ/mol"""
    return theta_max * K_ads * C / (1 + K_ads * C)

# 6. Gradient-driven (Nernst) - Ion equilibrium potential
def nernst_potential(C_out, C_in, z=1, RT_over_F=0.0257):
    """RT/F≈25.7 mV at 298K"""
    return (RT_over_F / z) * np.log(C_out / C_in)

# ============================================================
# Part 2: Unified Normalization Function
# ============================================================

def normalized_function(x, n=1):
    """f(x) = x^n / (1 + x^n) - unified form of all models"""
    return x**n / (1 + x**n)

# ============================================================
# Part 3: Recurrence Relation and Fixed Point
# ============================================================

def recurrence(phi):
    """phi_{n+1} = 1/(1+phi_n)"""
    return 1.0 / (1.0 + phi)

def recurrence_fixed_point():
    """Solve fixed point phi = 1/(1+phi) -> phi^2+phi-1=0"""
    return (np.sqrt(5) - 1) / 2  # 0.618034...

